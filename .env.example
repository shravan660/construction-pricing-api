# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Pricing Engine API
VERSION=1.0.0
DEBUG=false

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default, zero setup)
DATABASE_URL=sqlite:///./data/pricing.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/pricing_engine

# ─── Vector Search ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
FAISS_INDEX_PATH=./data/indexes/products.index
PRODUCT_META_PATH=./data/indexes/products_meta.json
TOP_K_DEFAULT=5

# ─── Feedback Decay ──────────────────────────────────────────────────────────
# Exponential decay: weight = exp(-lambda * days_elapsed)
# 0.1 => ~37% weight after 10 days, ~5% after 30 days
FEEDBACK_DECAY_LAMBDA=0.1

# ─── Scraper ─────────────────────────────────────────────────────────────────
SCRAPER_RATE_LIMIT_SECONDS=2.0
SCRAPER_MAX_PAGES_PER_CATEGORY=5
RAW_DATA_PATH=./data/raw
PROCESSED_DATA_PATH=./data/processed
