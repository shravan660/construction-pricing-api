data/pricing.db-wal
*.db-shm
*.db-wal

# Vector index (rebuilt on first run via build_index.py)
data/indexes/products.index
data/indexes/products_meta.json

# Raw / processed scraped data (large, regenerated by scraper)
data/raw/
data/processed/

# Assignment PDF
*.pdf

