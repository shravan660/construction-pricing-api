__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment
.venv/
venv/
env/

# Distribution / packaging
dist/
build/
*.egg-info/
.installed.cfg
*.egg

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checkers / linters
.mypy_cache/
.dmypy.json
.ruff_cache/
.pytype/

# Environment secrets
.env
.envrc

# HuggingFace model cache (large, re-downloaded automatically)
.cache/

